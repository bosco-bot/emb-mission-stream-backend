    <script async src="https://www.googletagmanager.com/gtag/js?id=G-R78T23LM6W"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-R78T23LM6W');
